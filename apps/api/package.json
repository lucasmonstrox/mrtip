{
  "name": "@workspace/api",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --target bun --outdir ./dist",
    "deploy": "wrangler deploy",
    "cf-dev": "wrangler dev",
    "lint": "eslint",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:sync": "bun run src/db/sync-sportmonks.ts",
    "db:reset": "docker compose down -v && docker compose up -d --wait && bun run src/db/migrate.ts && bun run src/db/sync-sportmonks.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^3.0.1",
    "@clerk/backend": "^3.8.4",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "ai": "^7.0.4",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "http-status-codes": "^2.3.0"
  }
}
